// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  uid          String   @unique @default(uuid())
  fullname     String
  email        String   @unique
  username     String   @unique
  password     String
  profileImage String?
  createdAt    DateTime @default(now())

  posts Post[]
}

enum PostType {
  REDFLAG
  TEA
}

model Post {
  id              Int      @id @default(autoincrement())
  type            PostType
  name            String
  nationality     String
  jobProfile      String
  currentLivingIn String
  age             Int
  title           String?
  photos          String[]
  content         String?  @db.Text
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
}
